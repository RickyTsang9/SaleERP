<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.business.mapper.WmsSaleOrderItemMapper">

    <resultMap type="WmsSaleOrderItem" id="WmsSaleOrderItemResult">
        <id     property="saleOrderItemId" column="sale_order_item_id" />
        <result property="saleOrderId"     column="sale_order_id" />
        <result property="productId"       column="product_id" />
        <result property="locationId"      column="location_id" />
        <result property="batchNo"         column="batch_no" />
        <result property="quantity"        column="quantity" />
        <result property="price"           column="price" />
        <result property="amount"          column="amount" />
    </resultMap>

    <sql id="selectWmsSaleOrderItemVo">
        select sale_order_item_id, sale_order_id, product_id, location_id, batch_no, quantity, price, amount
        from wms_sale_order_item
    </sql>

    <select id="selectWmsSaleOrderItemById" parameterType="Long" resultMap="WmsSaleOrderItemResult">
        <include refid="selectWmsSaleOrderItemVo"/>
        where sale_order_item_id = #{saleOrderItemId}
    </select>

    <select id="selectWmsSaleOrderItemList" parameterType="WmsSaleOrderItem" resultMap="WmsSaleOrderItemResult">
        <include refid="selectWmsSaleOrderItemVo"/>
        <where>
            <if test="saleOrderId != null">
                and sale_order_id = #{saleOrderId}
            </if>
            <if test="productId != null">
                and product_id = #{productId}
            </if>
        </where>
        order by sale_order_item_id desc
    </select>

    <select id="selectWmsSaleOrderItemsByOrderId" parameterType="Long" resultMap="WmsSaleOrderItemResult">
        <include refid="selectWmsSaleOrderItemVo"/>
        where sale_order_id = #{saleOrderId}
        order by sale_order_item_id asc
    </select>

    <insert id="insertWmsSaleOrderItem" parameterType="WmsSaleOrderItem" useGeneratedKeys="true" keyProperty="saleOrderItemId">
        insert into wms_sale_order_item
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="saleOrderId != null">sale_order_id,</if>
            <if test="productId != null">product_id,</if>
            <if test="locationId != null">location_id,</if>
            <if test="batchNo != null and batchNo != ''">batch_no,</if>
            <if test="quantity != null">quantity,</if>
            <if test="price != null">price,</if>
            <if test="amount != null">amount,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="saleOrderId != null">#{saleOrderId},</if>
            <if test="productId != null">#{productId},</if>
            <if test="locationId != null">#{locationId},</if>
            <if test="batchNo != null and batchNo != ''">#{batchNo},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="price != null">#{price},</if>
            <if test="amount != null">#{amount},</if>
        </trim>
    </insert>

    <update id="updateWmsSaleOrderItem" parameterType="WmsSaleOrderItem">
        update wms_sale_order_item
        <set>
            <if test="saleOrderId != null">sale_order_id = #{saleOrderId},</if>
            <if test="productId != null">product_id = #{productId},</if>
            <if test="locationId != null">location_id = #{locationId},</if>
            <if test="batchNo != null and batchNo != ''">batch_no = #{batchNo},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="price != null">price = #{price},</if>
            <if test="amount != null">amount = #{amount},</if>
        </set>
        where sale_order_item_id = #{saleOrderItemId}
    </update>

    <delete id="deleteWmsSaleOrderItemById" parameterType="Long">
        delete from wms_sale_order_item where sale_order_item_id = #{saleOrderItemId}
    </delete>

    <delete id="deleteWmsSaleOrderItemByIds" parameterType="Long">
        delete from wms_sale_order_item where sale_order_item_id in
        <foreach collection="array" item="saleOrderItemId" open="(" separator="," close=")">
            #{saleOrderItemId}
        </foreach>
    </delete>
</mapper>
