<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.business.mapper.WmsInboundMapper">

    <resultMap type="WmsInbound" id="WmsInboundResult">
        <id     property="inboundId"   column="inbound_id"   />
        <result property="inboundNo"   column="inbound_no"   />
        <result property="inboundType" column="inbound_type" />
        <result property="purchaseOrderId" column="purchase_order_id" />
        <result property="purchaseOrderNo" column="purchase_order_no" />
        <result property="supplierId"  column="supplier_id"  />
        <result property="warehouseId" column="warehouse_id" />
        <result property="totalQty"    column="total_qty"    />
        <result property="totalAmount" column="total_amount" />
        <result property="status"      column="status"       />
        <result property="auditBy"     column="audit_by"     />
        <result property="auditTime"   column="audit_time"   />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"  column="create_time"  />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"  column="update_time"  />
        <result property="remark"      column="remark"       />
    </resultMap>

    <sql id="selectWmsInboundVo">
        select inbound.inbound_id, inbound.inbound_no, inbound.inbound_type, inbound.purchase_order_id,
               purchase_order.order_no as purchase_order_no, inbound.supplier_id, inbound.warehouse_id,
               inbound.total_qty, inbound.total_amount, inbound.status, inbound.audit_by, inbound.audit_time,
               inbound.create_by, inbound.create_time, inbound.update_by, inbound.update_time, inbound.remark
        from wms_inbound inbound
        left join wms_purchase_order purchase_order on purchase_order.purchase_order_id = inbound.purchase_order_id
    </sql>

    <select id="selectWmsInboundById" parameterType="Long" resultMap="WmsInboundResult">
        <include refid="selectWmsInboundVo"/>
        where inbound.inbound_id = #{inboundId}
    </select>

    <select id="selectWmsInboundList" parameterType="WmsInbound" resultMap="WmsInboundResult">
        <include refid="selectWmsInboundVo"/>
        <where>
            <if test="inboundNo != null and inboundNo != ''">
                and inbound.inbound_no like concat('%', #{inboundNo}, '%')
            </if>
            <if test="inboundType != null and inboundType != ''">
                and inbound.inbound_type = #{inboundType}
            </if>
            <if test="purchaseOrderId != null">
                and inbound.purchase_order_id = #{purchaseOrderId}
            </if>
            <if test="purchaseOrderNo != null and purchaseOrderNo != ''">
                and purchase_order.order_no like concat('%', #{purchaseOrderNo}, '%')
            </if>
            <if test="supplierId != null">
                and inbound.supplier_id = #{supplierId}
            </if>
            <if test="warehouseId != null">
                and inbound.warehouse_id = #{warehouseId}
            </if>
            <if test="status != null and status != ''">
                and inbound.status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertWmsInbound" parameterType="WmsInbound" useGeneratedKeys="true" keyProperty="inboundId">
        insert into wms_inbound
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="inboundNo != null and inboundNo != ''">inbound_no,</if>
            <if test="inboundType != null">inbound_type,</if>
            <if test="purchaseOrderId != null">purchase_order_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="warehouseId != null">warehouse_id,</if>
            <if test="totalQty != null">total_qty,</if>
            <if test="totalAmount != null">total_amount,</if>
            <if test="status != null">status,</if>
            <if test="auditBy != null">audit_by,</if>
            <if test="auditTime != null">audit_time,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time,
            <if test="updateBy != null and updateBy != ''">update_by,</if>
            <if test="remark != null">remark,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="inboundNo != null and inboundNo != ''">#{inboundNo},</if>
            <if test="inboundType != null">#{inboundType},</if>
            <if test="purchaseOrderId != null">#{purchaseOrderId},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="warehouseId != null">#{warehouseId},</if>
            <if test="totalQty != null">#{totalQty},</if>
            <if test="totalAmount != null">#{totalAmount},</if>
            <if test="status != null">#{status},</if>
            <if test="auditBy != null">#{auditBy},</if>
            <if test="auditTime != null">#{auditTime},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate(),
            <if test="updateBy != null and updateBy != ''">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
        </trim>
    </insert>

    <update id="updateWmsInbound" parameterType="WmsInbound">
        update wms_inbound
        <set>
            <if test="inboundNo != null and inboundNo != ''">inbound_no = #{inboundNo},</if>
            <if test="inboundType != null">inbound_type = #{inboundType},</if>
            <if test="purchaseOrderId != null">purchase_order_id = #{purchaseOrderId},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="warehouseId != null">warehouse_id = #{warehouseId},</if>
            <if test="totalQty != null">total_qty = #{totalQty},</if>
            <if test="totalAmount != null">total_amount = #{totalAmount},</if>
            <if test="status != null">status = #{status},</if>
            <if test="auditBy != null">audit_by = #{auditBy},</if>
            <if test="auditTime != null">audit_time = #{auditTime},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where inbound_id = #{inboundId}
    </update>

    <delete id="deleteWmsInboundById" parameterType="Long">
        delete from wms_inbound where inbound_id = #{inboundId}
    </delete>

    <delete id="deleteWmsInboundByIds" parameterType="Long">
        delete from wms_inbound where inbound_id in
        <foreach collection="array" item="inboundId" open="(" separator="," close=")">
            #{inboundId}
        </foreach>
    </delete>

    <select id="selectMaxInboundNoByPrefix" parameterType="String" resultType="String">
        select max(inbound_no) from wms_inbound where inbound_no like concat(#{noPrefix}, '%')
    </select>

    <update id="refreshTotalByInboundId" parameterType="Long">
        update wms_inbound
        set total_qty = ifnull((select sum(quantity) from wms_inbound_item where inbound_id = #{inboundId}), 0),
            total_amount = ifnull((select sum(amount) from wms_inbound_item where inbound_id = #{inboundId}), 0),
            update_time = sysdate()
        where inbound_id = #{inboundId}
    </update>

    <update id="updateWmsInboundStatus">
        update wms_inbound
        set status = #{newStatus},
            audit_by = #{auditBy},
            audit_time = case when #{auditBy} is not null and #{auditBy} != '' then sysdate() else null end,
            update_by = #{updateBy},
            update_time = sysdate()
        where inbound_id = #{inboundId}
          and status = #{oldStatus}
    </update>
</mapper>
