<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.business.mapper.FinPaymentMapper">
    
    <resultMap type="FinPayment" id="FinPaymentResult">
        <result property="paymentId"    column="payment_id"    />
        <result property="payableId"    column="payable_id"    />
        <result property="purchaseOrderId"    column="purchase_order_id"    />
        <result property="purchaseOrderNo"    column="purchase_order_no"    />
        <result property="supplierId"    column="supplier_id"    />
        <result property="amount"    column="amount"    />
        <result property="paymentTime"    column="payment_time"    />
        <result property="paymentMethod"    column="payment_method"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectFinPaymentVo">
        select payment_id, payable_id, purchase_order_id,
               (select order_no from wms_purchase_order where purchase_order_id = fin_payment.purchase_order_id) as purchase_order_no,
               supplier_id, amount, payment_time, payment_method, remark, create_by, create_time, update_by, update_time
        from fin_payment
    </sql>

    <select id="selectFinPaymentList" parameterType="FinPayment" resultMap="FinPaymentResult">
        <include refid="selectFinPaymentVo"/>
        <where>  
            <if test="payableId != null "> and payable_id = #{payableId}</if>
            <if test="purchaseOrderId != null "> and purchase_order_id = #{purchaseOrderId}</if>
            <if test="purchaseOrderNo != null and purchaseOrderNo != ''">
                and purchase_order_id in (select purchase_order_id from wms_purchase_order where order_no like concat('%', #{purchaseOrderNo}, '%'))
            </if>
            <if test="supplierId != null "> and supplier_id = #{supplierId}</if>
            <if test="paymentMethod != null and paymentMethod != ''"> and payment_method = #{paymentMethod}</if>
            <if test="params.beginPaymentTime != null and params.beginPaymentTime != ''">
                and payment_time &gt;= #{params.beginPaymentTime}
            </if>
            <if test="params.endPaymentTime != null and params.endPaymentTime != ''">
                and payment_time &lt;= #{params.endPaymentTime}
            </if>
        </where>
        order by payment_id desc
    </select>
    
    <select id="selectFinPaymentByPaymentId" parameterType="Long" resultMap="FinPaymentResult">
        <include refid="selectFinPaymentVo"/>
        where payment_id = #{paymentId}
    </select>
        
    <insert id="insertFinPayment" parameterType="FinPayment" useGeneratedKeys="true" keyProperty="paymentId">
        insert into fin_payment
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="payableId != null">payable_id,</if>
            <if test="purchaseOrderId != null">purchase_order_id,</if>
            <if test="supplierId != null">supplier_id,</if>
            <if test="amount != null">amount,</if>
            <if test="paymentTime != null">payment_time,</if>
            <if test="paymentMethod != null">payment_method,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="payableId != null">#{payableId},</if>
            <if test="purchaseOrderId != null">#{purchaseOrderId},</if>
            <if test="supplierId != null">#{supplierId},</if>
            <if test="amount != null">#{amount},</if>
            <if test="paymentTime != null">#{paymentTime},</if>
            <if test="paymentMethod != null">#{paymentMethod},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateFinPayment" parameterType="FinPayment">
        update fin_payment
        <trim prefix="SET" suffixOverrides=",">
            <if test="payableId != null">payable_id = #{payableId},</if>
            <if test="purchaseOrderId != null">purchase_order_id = #{purchaseOrderId},</if>
            <if test="supplierId != null">supplier_id = #{supplierId},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="paymentTime != null">payment_time = #{paymentTime},</if>
            <if test="paymentMethod != null">payment_method = #{paymentMethod},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where payment_id = #{paymentId}
    </update>

    <delete id="deleteFinPaymentByPaymentId" parameterType="Long">
        delete from fin_payment where payment_id = #{paymentId}
    </delete>

    <delete id="deleteFinPaymentByPaymentIds" parameterType="String">
        delete from fin_payment where payment_id in 
        <foreach item="paymentId" collection="array" open="(" separator="," close=")">
            #{paymentId}
        </foreach>
    </delete>
</mapper>
